# =============================================================================
# Skills Lab — Environment Configuration
# =============================================================================
# Copy this file to .env and customize the values for your environment.
# Values here are loaded by python-dotenv at application startup.
#
# Priority order (highest wins):
#   1. Explicit constructor argument in code
#   2. Environment variable (system-level)
#   3. This .env file
#   4. Built-in default value
# =============================================================================

# -----------------------------------------------------------------------------
# Workspace
# -----------------------------------------------------------------------------

# Root directory for all persisted data.
# Contains: brain.db (SQLite), skills/ (SKILL.md files), .cache/ (embeddings).
# Default: ./workspace (relative to the skills_lab directory)
SKILLS_LAB_WORKSPACE=./workspace

# Set by MCP host (Claude Desktop, GitHub Copilot, Cursor) to the root of the
# currently opened project. Used to auto-detect the repository name for repo-scoped
# search and to set the default repo_name when saving skills.
# Typically you do NOT set this manually — it is injected by the MCP host.
# WORKSPACE_FOLDER=/path/to/your/project

# -----------------------------------------------------------------------------
# Embedding Model (Semantic Search)
# -----------------------------------------------------------------------------

# Primary sentence-transformer model for computing dense vector embeddings.
# Requires the [semantic] extra: pip install -e ".[semantic]"
# If this model fails to load, the system falls back to the fallback model.
# Default: BAAI/bge-small-en-v1.5 (512 tokens, 384 dims)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Fallback embedding model used when the primary model cannot be loaded.
# This is configured in core/config.py (SkillsLabConfig.fallback_embedding_model)
# and currently defaults to: sentence-transformers/all-MiniLM-L6-v2
# To override, modify the config in code.
# FALLBACK_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# -----------------------------------------------------------------------------
# Search
# -----------------------------------------------------------------------------

# Maximum number of results returned by search_skills (Tier 1).
# Applies to the final fused result set after RRF.
# Recommended range: 1-50. Higher values consume more context window.
SEARCH_TOP_K=5

# Reciprocal Rank Fusion constant k. Controls how rank differences are flattened.
# Higher values (e.g., 100) give more weight to consensus across ranking methods.
# Lower values (e.g., 30) favor items with higher absolute ranks.
# Configured in core/config.py (SkillsLabConfig.rrf_k). Default: 60.
# RRF_K=60

# Cosine similarity threshold for duplicate detection.
# After ARCHIVE or DERIVE, if a new skill's embedding has similarity >= this
# value with any existing active skill, a duplicate warning is returned.
# Recommended range: 0.5-1.0. Lower values = more aggressive dedup warnings.
# Configured in core/config.py (SkillsLabConfig.dedup_threshold). Default: 0.85.
# DEDUP_THRESHOLD=0.85

# -----------------------------------------------------------------------------
# Dashboard Server
# -----------------------------------------------------------------------------

# Host address for the dashboard HTTP server.
# Use 127.0.0.1 to restrict access to localhost only.
SKILLS_LAB_HOST=0.0.0.0

# Port for the dashboard HTTP server.
SKILLS_LAB_PORT=7788

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Logging level for the Skills Lab application.
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
SKILLS_LAB_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database (Advanced)
# -----------------------------------------------------------------------------

# SQLite database filename. Stored inside SKILLS_LAB_WORKSPACE.
# You typically do not need to change this.
# Configured in core/config.py (SkillsLabConfig.db_filename). Default: brain.db
# DB_FILENAME=brain.db
